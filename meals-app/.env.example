# Required env vars for local dev. In production, set these in the Vercel dashboard
# at TEAM level so they're shared across all pinkcrocodile.dev projects.

# JSON array of users. Both username and password as strings.
AUTH_USERS_JSON=[{"username":"ben","password":"replace-me"},{"username":"jenny","password":"replace-me"}]

# Long random string used to sign session JWTs. Must be at least 32 chars.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_SECRET=replace-with-a-long-random-string

# Anthropic API key for the chat feature
ANTHROPIC_API_KEY=sk-ant-...

# Optional: cookie domain for cross-subdomain SSO across pinkcrocodile.dev apps.
# Set this to ".pinkcrocodile.dev" (with the leading dot) in production for shared login.
# Leave unset for local dev and preview deployments.
COOKIE_DOMAIN=

# Postgres connection string. In production, the Neon-Vercel integration
# auto-injects this — you don't need to set it manually in Vercel.
# For local dev, you can either use Neon's connection string or run a local Postgres.
DATABASE_URL=postgresql://user:password@host/dbname
